{
  "name": "unplugin-gem",
  "version": "0.1.1",
  "description": "Universal plugin for Gem element transformations (Vite/Webpack/Rollup/esbuild)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./vite": {
      "types": "./src/vite.ts",
      "development": "./src/vite.ts",
      "import": "./dist/vite.js",
      "default": "./dist/vite.js"
    },
    "./webpack": {
      "types": "./src/webpack.ts",
      "development": "./src/webpack.ts",
      "import": "./dist/webpack.js",
      "default": "./dist/webpack.js"
    },
    "./rollup": {
      "types": "./src/rollup.ts",
      "development": "./src/rollup.ts",
      "import": "./dist/rollup.js",
      "default": "./dist/rollup.js"
    },
    "./esbuild": {
      "types": "./src/esbuild.ts",
      "development": "./src/esbuild.ts",
      "import": "./dist/esbuild.js",
      "default": "./dist/esbuild.js"
    },
    "./rspack": {
      "types": "./src/rspack.ts",
      "development": "./src/rspack.ts",
      "import": "./dist/rspack.js",
      "default": "./dist/rspack.js"
    },
    "./rolldown": {
      "types": "./src/rolldown.ts",
      "development": "./src/rolldown.ts",
      "import": "./dist/rolldown.js",
      "default": "./dist/rolldown.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "start": "pnpm build --watch",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "unplugin",
    "vite",
    "webpack",
    "rollup",
    "esbuild",
    "gem",
    "web-components",
    "swc"
  ],
  "author": "mantou132",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mantou132/gem.git",
    "directory": "packages/unplugin-gem"
  },
  "bugs": {
    "url": "https://github.com/mantou132/gem/issues"
  },
  "homepage": "https://github.com/mantou132/gem#readme",
  "dependencies": {
    "@swc/core": "^1.9.3",
    "@swc/helpers": "^0.5.21",
    "swc-plugin-gem": "^0.1.9",
    "unplugin": "^3.0.0"
  },
  "devDependencies": {
    "@gemjs/config": "^2.1.3",
    "@types/node": "^22.13.10",
    "typescript": "^5.6.2"
  },
  "peerDependencies": {
    "@rspack/core": ">=0.0.0",
    "esbuild": ">=0.20.0",
    "rolldown": ">=0.0.0",
    "rollup": ">=3.0.0",
    "vite": ">=4.0.0",
    "webpack": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "esbuild": {
      "optional": true
    },
    "rollup": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    },
    "@rspack/core": {
      "optional": true
    },
    "rolldown": {
      "optional": true
    }
  }
}
